input_list=input("Enter the list a Numbers: \n")
split_list=list(input_list.split())
zeros=0
positive=0
negative=0
for i in split_list:
    num=int(i)
    if num==0:
        zeros+=1
    elif num<1:
        negative+=1
    else:
        positive+=1
print("Positive Numbers = ",positive)
print("Negative Numbers = ",negative)
print("Zeros = ",zeros)


